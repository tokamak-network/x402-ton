{
  "name": "@x402-ton/facilitator",
  "version": "0.1.0",
  "description": "Facilitator service for x402-ton payment settlement on TON",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/x402-ton",
    "directory": "packages/facilitator"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/lib.js",
