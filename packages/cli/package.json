{
  "name": "@x402-ton/cli",
  "version": "0.1.0",
  "description": "CLI tool for interacting with x402-ton payment protocol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/x402-ton",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "x402-ton": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@x402-ton/client": "^0.1.0",
    "@x402-ton/common": "^0.1.0",
    "viem": "^2.30.0"
  }
}
