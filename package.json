{
  "name": "x402-ton",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "packages/*",
    "examples/clients/*",
    "examples/servers/*"
  ],
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean",
    "typecheck": "turbo typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "changeset version",
    "publish": "turbo build && changeset publish",
    "release": "npm run build && changeset publish",
    "fund-testnet": "node --import=tsx scripts/fund-testnet.ts"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
